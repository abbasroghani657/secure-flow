# Copy to .env and adjust. Never commit the real .env.
APP_NAME=SecureFlow
ENVIRONMENT=development
DATABASE_URL=sqlite:///./secureflow.db
# Generate a long random string, e.g. python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SCAN_HTTP_TIMEOUT=12
# Optional: absolute path to a nuclei binary (defaults to backend/bin/nuclei.exe).
NUCLEI_PATH=

# Worker / queue. Set WORKER_IN_PROCESS=false in production and run `python -m app.worker`.
WORKER_IN_PROCESS=true
MAX_CONCURRENT_SCANS=3

# Email alerts. Leave SMTP_HOST empty to log alerts instead of sending them.
ALERTS_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SecureFlow <alerts@secureflow.app>
SMTP_STARTTLS=true
APP_BASE_URL=http://localhost:5173
